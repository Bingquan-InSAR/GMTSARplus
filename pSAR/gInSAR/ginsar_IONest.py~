def ion(dint_low,dint_high):
    '''
    Generate a ionospheric component from one low-frequency interferogram and 
    another high-frequency interferogram
    The way used in this function was proposed by 
    
    Gomba, G., Parizzi, A., Zan, F. De, Eineder, M., Bamler, R., 2016. 
    Toward Operational Compensation of Ionospheric Effects in SAR Interferograms: 
    The Split-Spectrum Method. IEEE Trans. Geosci. Remote Sens. 
    54, 1446–1461. doi:10.1109/TGRS.2015.2481079

    by Wanpeng Feng, @CCRS/NRCan, 2017-08-28
    ''' 
    #
    #
    unw_low = glob.glob(dint_low+'/DINT*/*.adf.unw')[0]
    unw_high= glob.glob(dint_high+'/DINT*/*.adf.unw')[0]
    lowname = os.path.basename(unw_low)
    masterdate = lowname[0:8]
    #  
    # update individual frequency
    #
    LOWslcpar = glob.glob(dint_low+'/RSLC*/%s*.par' % masterdate)[0]
    info = pGAMMA.gamma_slcpar(LOWslcpar)
    # low band
    LOWslc    = glob.glob(dint_low+'/RSLC*/%s*.rslc' % masterdate)[0]
    freqs = pGAMMA.gamma_slcpar2freqs(LOWslcpar)
    LOWwid,LOWmean = pSLC.gSLC_bandwidth(LOWslc,sample_lines=100,bigendian=True,threshold=10)
    fl = freqs[0]  #+ LOWmean
    bw = freqs[2]
    #
    SPL = 299792458
    # 
    wl_L = SPL / fl * 100.
    #
    # high band
    HIGHslcpar = glob.glob(dint_high+'/RSLC*/%s*.par' % masterdate)[0]
    HIGHslc    = glob.glob(dint_high+'/RSLC*/%s*.rslc' % masterdate)[0]
    #
    freqs = pGAMMA.gamma_slcpar2freqs(HIGHslcpar)
    HIGwid,HIGmean = pSLC.gSLC_bandwidth(HIGHslc,sample_lines=100,bigendian=True,threshold=10)
    fh = freqs[0] #+ HIGmean
    #
    # speed of light
    SPL = 299792458.
    wl_H = SPL / fh * 100.
    #
    # original band
    #
    slcpar = glob.glob('RSLC*/%s*.rslc.par' % masterdate)[0]
    info = pGAMMA.gamma_slcpar(slcpar)
    f0   = float(info['radar_frequency'][0])  # center frequency
    wl0  = pGAMMA.gamma_slcpar2wl(slcpar) * 100.    # wavelength
    #
    diff_par = glob.glob(dint_high+'/DINT*/*.diff_par')[0]
    width,file_length = pGAMMA.gamma_diff_par(diff_par)
    #
    x0,y0 = int(width/2),int(file_length/2)
    #
    phs_low = pSAR.roipac.roi_read(unw_low, dims=[width,file_length],ingamma=True)
    phs_hig = pSAR.roipac.roi_read(unw_high,dims=[width,file_length],ingamma=True)
    #
    ref1,ref2 = phs_low[x0,y0],phs_hig[x0,y0]
    print(" ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++")
    print(" + RAW    RSLC   PAR: %s" % os.path.abspath(slcpar))
    print(" + LOW-band RSLC PAR: %s" % os.path.abspath(LOWslcpar))
    print(" + HIG-band RSLC PAR: %s" % os.path.abspath(HIGHslcpar))
    print(" + Wavelengths of original,low and high bands: %s %f %f" % (wl0,wl_L,wl_H))
    print(" + Reference pixel @ %d %d with %f and %f" % (x0,y0,ref1,ref2))
    print(" ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++")
    #
    phs_low[phs_low != 0] = phs_low[phs_low != 0] - ref1
    phs_hig[phs_hig != 0] = phs_hig[phs_hig != 0] - ref2
    #
    phs_low_los = phs_low #* -1. / (4 * np.pi) * wl_L
    phs_hig_los = phs_hig #* -1. / (4 * np.pi) * wl_H
    #
    # A bug fixed on 28/08/2017
    # we should run the correction with light of sight in cm
    #
    ion     = (fl * fh) / (f0 * (fh**2 - fl**2)) * (fh * phs_low_los - fl * phs_hig_los)
    ion_non = f0       / (fh**2 - fl**2) * (fh * phs_hig_los - fl * phs_low_los)
    # ion     = ion      / wl0 * -4.0 * np.pi / 100.
    # ion_non = ion_non  / wl0 * -4.0 * np.pi / 100.
    #
    phs_low_los,phs_hig_los,ion,ion_non = pION.ion_refine(fl,fh,f0,bw,phs_low_los,phs_hig_los,ion,ion_non)
    phs_low_los,phs_hig_los,ion,ion_non = pION.ion_refine(fl,fh,f0,bw,phs_low_los,phs_hig_los,ion,ion_non)
    #
    return phs_low_los,phs_hig_los,ion,ion_non,width,file_length,f0,bw
