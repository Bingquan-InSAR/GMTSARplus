def mk_newInfDIR(mslc,sslc,outdir,rlk,azlk):
    #
    mslc = os.path.abspath(mslc)
    sslc = os.path.abspath(sslc)
    #
    mbname = os.path.basename(mslc).split('.rslc')[0]
    masterdate = mbname[0:8]
    rslcdir = outdir+'/RSLC_M%s' % masterdate
    if not os.path.exists(rslcdir):
       os.makedirs(rslcdir)
    #
    outmrslc = rslcdir+'/'+mbname+'.rslc'
    outmpar  = rslcdir+'/'+mbname+'.rslc.par'
    if not os.path.exists(outmrslc):
       os.symlink(mslc,outmrslc)
       os.symlink(mslc+'.par',outmpar)
    #
    #outmpar_ref  = rslcdir+'/'+mbname+'.rslc.par.ref'
    #if not os.path.exists(outmpar_ref):
    #   os.symlink(mslc+'.par.ref',outmpar_ref)
    #
    sbname = os.path.basename(sslc).split('.rslc')[0]
    outsrslc = rslcdir+'/'+sbname+'.rslc'
    outspar  = rslcdir+'/'+sbname+'.rslc.par'
    if not os.path.exists(outsrslc):
       os.symlink(sslc,outsrslc)
       os.symlink(sslc+'.par',outspar)
    #
    #outspar_ref  = rslcdir+'/'+sbname+'.rslc.par.ref'
    #if not os.path.exists(outspar_ref):
    #   os.symlink(sslc+'.par.ref',outspar_ref)
    #
    dem_rdc = glob.glob('GEO*RLK%d_AZLK%d/*dem.rdc' % (rlk,azlk))
    if len(dem_rdc) > 0:
       dem_rdc = dem_rdc[0]
       m_bname = os.path.basename(outmrslc)
       s_bname = os.path.basename(outsrslc)
       dint_dir = outdir+'/DINT_M%s_RLK%d_AZLK%d' % (masterdate,rlk,azlk)
       rmli = glob.glob('RMLI_M*_RLK%d_AZLK%d/%s*.rmli' % (rlk,azlk,mbname))[0]
       #
       outint = dint_dir+'/'+m_bname.split('.')[0]+'_'+s_bname.split('.')[0]+'.int'
       #
       if not os.path.exists(dint_dir):
          os.makedirs(dint_dir)
       pGAMMA.gamma_SLC_intf(outmrslc,outsrslc,rlk,azlk,outint,offpar=None)
       #rslc2geo = 'ginsar_rslc2geo.sh %s %s %s %s %s %d %d 5 64 0.85 0.05 %s 0 0.25 0.1 0 0' % \
       #               (m_bname,s_bname,rslcdir,dem_rdc,dint_dir,rlk,azlk,rmli)
       rslc2geo = 'ginsar_rslc2geo.sh %s %s %s %s %s %d %d 5 64 0.85 0.05 %s ' % \
                      (m_bname,s_bname,rslcdir,dem_rdc,dint_dir,rlk,azlk,rmli)
    else:
       rslc2geo = None 
    return rslc2geo
#
def bandcentr(nband):
    #
    bws = np.linspace(-0.5,0.5,num=(nband+1))
    return bws
#
def rngsplit(inslc,outslc,fc,bw,amp,fc0=None,bw0=None):
    #
    if fc0 is not None:
       rngsplit = 'pSAR_splitSLCRNG.py %s %s %f %f -amp %f -fc %f -bw %f' % (inslc,outslc,fc,bw,amp,fc0,bw0)
    else:
       rngsplit = 'pSAR_splitSLCRNG.py %s %s %f %f -amp %f' % (inslc,outslc,fc,bw,amp)
    #
    print(' ginsar_IONest: %s' % rngsplit)
    os.system(rngsplit)
    return True
#
def bandsplit_win(nband):
    bws = bandcentr(nband)
    frac = 1. / nband
    # lower bound
    fa1 = (bws[0]+bws[1])/2. 
    bw_low = frac
    #
    # upper bound
    fa2 = (bws[nband-1]+bws[nband])/2.
    bw_high = frac
    return fa1,fa2,bw_low,bw_high
    #
def bandsplit_spec(slcpar1,slcpar2,nband,obw=None):
    #
    # info from master_par
    parinfo             = pGAMMA.gamma_slcpar(slcpar1)
    frequency_1         = float(parinfo['radar_frequency'][0])
    chirp_bandwidth_1   = float(parinfo['chirp_bandwidth'][0])
    adc_sampling_rate_1 = float(parinfo['adc_sampling_rate'][0])
    r_bw_frac_1         =  chirp_bandwidth_1 / adc_sampling_rate_1
    # info from slave_par
    #
    parinfo             = pGAMMA.gamma_slcpar(slcpar2)
    frequency_2         = float(parinfo['radar_frequency'][0])
    chirp_bandwidth_2   = float(parinfo['chirp_bandwidth'][0])
    adc_sampling_rate_2 = float(parinfo['adc_sampling_rate'][0])
    r_bw_frac_2 = chirp_bandwidth_2 / adc_sampling_rate_2
    #
    r_bw_frac = np.min([r_bw_frac_1,r_bw_frac_2])
    # 
    # lower bound
    # 3 bands mode
    frac = 1. / nband
    bws = bandcentr(nband)
    fa1 = (bws[0]+bws[1])/2. * r_bw_frac
    # 
    # upper bound
    fa2 = (bws[nband-1]+bws[nband])/2 * r_bw_frac
    # fa2 = (bws[3]+bws[4])/2 * r_bw_frac
    #  
    #
    print(" r_bw_frac, frac, fa1, fa2: %f %f %f %f" % (r_bw_frac,frac,fa1,fa2))
    bw_low  =  frac * r_bw_frac
    bw_high =  frac * r_bw_frac
    if obw is not None:
       if obw < bw_high:
          bw_low = obw
          bw_high = obw
          print(" Fix bandwidth of low and high @ %s " % obw)
    #
    return fa1,fa2,bw_low,bw_high
